{
  "buildCommand": "pnpm build",
  "installCommand": "pnpm install",
  "outputDirectory": "dist/public",
  "framework": "vite",
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "server/_core/index.ts"
    },
    {
      "source": "/auth/(.*)",
      "destination": "server/_core/index.ts"
    },
    {
      "source": "/manus-storage/(.*)",
      "destination": "server/_core/index.ts"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
