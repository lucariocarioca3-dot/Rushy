# ==========================================
# CONFIGURAÇÕES DO CHAT IA (GOOGLE GEMINI)
# ==========================================
# Cole sua chave do Google Gemini aqui:
GOOGLE_GEMINI_API_KEY="COLOQUE_SUA_CHAVE_AQUI"

# ==========================================
# CONFIGURAÇÕES DE BANCO DE DADOS
# ==========================================
# Se estiver usando o Supabase, cole a URL aqui:
DATABASE_URL="mysql://ai_reader:sua_senha_segura@localhost:3306/rushy"

# ==========================================
# OUTRAS CONFIGURAÇÕES
# ==========================================
JWT_SECRET="sua_chave_secreta_aqui"
VITE_APP_ID="rushy-app"
NODE_ENV="production"
